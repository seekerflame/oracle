# ═══════════════════════════════════════
# Oracle Trading Engine — Environment Setup
# ═══════════════════════════════════════
# Copy this file to .env and fill in your keys
# NEVER commit .env to version control
# ═══════════════════════════════════════

# Market Data (Alpaca — free paper trading available at alpaca.markets)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Ethereum/Polygon Wallet
ETH_WALLET_ADDRESS=
ETH_PRIVATE_KEY=

# Solana Wallet (optional — for crypto scanning)
SOLANA_WALLET_ADDRESS=
SOLANA_PRIVATE_KEY=

# Recovery Wallet (optional)
RECOVERY_WALLET=
